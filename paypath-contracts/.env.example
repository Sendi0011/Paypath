# ── Deployment ──────────────────────────────────────────────────────
# Your wallet private key (never commit the real .env!)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# BaseScan API key for contract verification
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=YourBaseScanApiKeyHere

# ── AgentKit ────────────────────────────────────────────────────────
# Get from: https://portal.cdp.coinbase.com
CDP_API_KEY_NAME=organizations/your-org/apiKeys/your-key
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"
AGENTKIT_WALLET_DATA={"walletId":"...","seed":"..."}

# ── Contract addresses (filled after deployment) ─────────────────
REGISTRY_ADDRESS=0x
PAYROLL_ADDRESS=0x
ATTESTATION_ADDRESS=0x
CREDIT_ADDRESS=0x

# ── Gas reporting ────────────────────────────────────────────────
REPORT_GAS=false
